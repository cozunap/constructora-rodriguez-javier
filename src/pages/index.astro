---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Constructora Rodríguez Javier | Inicio">
  <!-- ═══════════════════════════════════════════════
       HERO
  ════════════════════════════════════════════════ -->
  <section class="relative min-h-[90vh] md:min-h-screen flex items-center pt-24 pb-16 overflow-hidden bg-navy" id="inicio" aria-label="Hero">
    <div class="absolute inset-0 z-0 opacity-40 mix-blend-overlay">
      <img src="/assets/images/projects/duran-1.webp" alt="Hero Background" class="w-full h-full object-cover">
    </div>
    <div class="absolute inset-0 z-0 bg-gradient-to-r from-navy via-navy/80 to-transparent"></div>
    
    <div class="w-full max-w-7xl mx-auto px-6 md:px-12 xl:px-16 relative z-10 grid grid-cols-1 lg:grid-cols-2 gap-12">
      <div class="flex flex-col items-start justify-center text-left">
        <p class="text-xs md:text-sm font-semibold tracking-[0.2em] uppercase text-gold mb-6" data-i18n="hero-tag">Expertos en Remodelaciones &amp; Construcción</p>
        <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl text-white font-normal leading-[1.15] tracking-tight mb-8" data-i18n="hero-title">Transformamos Espacios,<br>Construimos Sueños</h1>
        <p class="text-base md:text-lg text-white/80 leading-relaxed max-w-lg mb-10" data-i18n="hero-desc">Diseños a la medida y remodelaciones de alto nivel en Santo Domingo con estándares europeos de calidad, puntualidad y acabados premium.</p>
        <div class="flex flex-wrap items-center gap-4">
          <a href="/properties" class="btn-gold" data-i18n="hero-cta-projects">Ver Propiedades</a>
          <a href="/contact" class="btn-outline-white" data-i18n="hero-cta-contact">Cotizar Gratis</a>
        </div>
      </div>
      <div></div>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="bg-white py-12 border-b border-mid/50 relative z-20 -mt-8 mx-6 md:mx-12 xl:mx-16 rounded-xl shadow-2xl shadow-navy/5">
    <div class="w-full max-w-7xl mx-auto px-6 md:px-12 grid grid-cols-2 lg:grid-cols-4 gap-8 md:gap-12 divide-x divide-mid/30">
      <div class="flex flex-col items-center text-center px-4">
        <strong class="font-serif text-3xl md:text-4xl text-navy mb-2">120+</strong>
        <span class="text-sm font-medium tracking-wide text-muted uppercase" data-i18n="stat-projects">Proyectos</span>
      </div>
      <div class="flex flex-col items-center text-center px-4">
        <strong class="font-serif text-3xl md:text-4xl text-navy mb-2">15</strong>
        <span class="text-sm font-medium tracking-wide text-muted uppercase" data-i18n="stat-experience">Años de Experiencia</span>
      </div>
      <div class="flex flex-col items-center text-center px-4">
        <strong class="font-serif text-3xl md:text-4xl text-navy mb-2">98%</strong>
        <span class="text-sm font-medium tracking-wide text-muted uppercase" data-i18n="stat-satisfaction">Clientes Satisfechos</span>
      </div>
      <div class="flex flex-col items-center text-center px-4">
        <strong class="font-serif text-3xl md:text-4xl text-navy mb-2">RD &amp; USA</strong>
        <span class="text-sm font-medium tracking-wide text-muted uppercase" data-i18n="hero-stat-reach">Coordinación Remota</span>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       FEATURED PROPERTIES
  ════════════════════════════════════════════════ -->
  <section class="py-24 md:py-32" id="propiedades" aria-label="Propiedades destacadas">
    <div class="w-full max-w-7xl mx-auto px-6 md:px-12 xl:px-16">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-8 mb-16">
        <div class="fade-up">
          <p class="text-xs font-semibold tracking-[0.2em] uppercase text-gold mb-4" data-i18n="re-subtitle">Luxury Real Estate</p>
          <div class="w-12 h-0.5 bg-gold mb-6"></div>
          <h2 class="font-serif text-3xl md:text-4xl lg:text-5xl text-navy" data-i18n="re-title">Propiedades Destacadas</h2>
        </div>
        <a href="/properties" class="btn-outline fade-up" data-i18n="view-all">Ver Todas</a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="featured-props">
        <!-- Populated by app.js (static placeholders below for SEO/fallback) -->
        <div class="prop-card fade-up bg-white rounded-xl overflow-hidden shadow-lg shadow-navy/5 hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 border border-mid/30 group">
          <div class="relative h-64 overflow-hidden">
            <img src="/assets/images/projects/duran-2.webp" alt="Residencial Duran" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy">
            <span class="absolute top-4 right-4 bg-gold text-white text-xs font-bold tracking-wider uppercase px-3 py-1.5 rounded shadow-md" data-i18n="tag-dev">Preventa</span>
          </div>
          <div class="p-8">
            <p class="text-sm text-gold font-medium tracking-wide mb-2">San Isidro, Santo Domingo Este</p>
            <h3 class="font-serif text-2xl text-navy mb-3" data-i18n="re-duran-title">Residencial Duran</h3>
            <p class="text-muted mb-6">Desde US$175,000</p>
            <div class="flex items-center justify-between pt-4 border-t border-mid/40 text-sm text-navy/80">
              <span class="flex items-center gap-2">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 9V5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v4"/><path d="M2 11v5a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-5"/><path d="M2 11h20"/></svg>
                3 Hab.
              </span>
              <span class="flex items-center gap-2">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 6 6.5 3.5a1.5 1.5 0 0 0-1-.5C4.683 3 4 3.683 4 4.5V17a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-5"/><line x1="10" y1="5" x2="8" y2="7"/><line x1="2" y1="12" x2="22" y2="12"/></svg>
                3.5 Baños
              </span>
              <span class="flex items-center gap-2">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="1"/><path d="M3 9h18M9 21V9"/></svg>
                150 m²
              </span>
            </div>
          </div>
        </div>
        <!-- Card 2 -->
        <div class="prop-card fade-up bg-white rounded-xl overflow-hidden shadow-lg shadow-navy/5 hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 border border-mid/30 group" style="animation-delay: 100ms">
          <div class="relative h-64 overflow-hidden">
            <img src="/assets/images/projects/rodriguez-ii-1.webp" alt="Residencial Rodríguez II" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy">
            <span class="absolute top-4 right-4 bg-gold text-white text-xs font-bold tracking-wider uppercase px-3 py-1.5 rounded shadow-md" data-i18n="tag-dev">Preventa</span>
          </div>
          <div class="p-8">
            <p class="text-sm text-gold font-medium tracking-wide mb-2">San Isidro, Santo Domingo Este</p>
            <h3 class="font-serif text-2xl text-navy mb-3" data-i18n="re-rod-title">Residencial Rodríguez II</h3>
            <p class="text-muted mb-6">Desde US$175,000</p>
            <div class="flex items-center justify-between pt-4 border-t border-mid/40 text-sm text-navy/80">
              <span class="flex items-center gap-2">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 9V5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v4"/><path d="M2 11v5a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-5"/><path d="M2 11h20"/></svg>
                3 Hab.
              </span>
              <span class="flex items-center gap-2">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 6 6.5 3.5a1.5 1.5 0 0 0-1-.5C4.683 3 4 3.683 4 4.5V17a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-5"/><line x1="10" y1="5" x2="8" y2="7"/><line x1="2" y1="12" x2="22" y2="12"/></svg>
                2.5 Baños
              </span>
              <span class="flex items-center gap-2">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="1"/><path d="M3 9h18M9 21V9"/></svg>
                150 m²
              </span>
            </div>
          </div>
        </div>
        <!-- Card 3 -->
        <div class="prop-card fade-up bg-white rounded-xl overflow-hidden shadow-lg shadow-navy/5 hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 border border-mid/30 group" style="animation-delay: 200ms">
          <div class="relative h-64 overflow-hidden">
            <img src="/assets/images/projects/duran-3.webp" alt="Villa Marina" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy">
            <span class="absolute top-4 right-4 bg-navy text-white text-xs font-bold tracking-wider uppercase px-3 py-1.5 rounded shadow-md">En Venta</span>
          </div>
          <div class="p-8">
            <p class="text-sm text-gold font-medium tracking-wide mb-2">Casa de Campo, La Romana</p>
            <h3 class="font-serif text-2xl text-navy mb-3" data-i18n="re-c1-title">Villa Marina &amp; Golf</h3>
            <p class="text-muted mb-6">Precio a consultar</p>
            <div class="flex items-center justify-between pt-4 border-t border-mid/40 text-sm text-navy/80">
              <span class="flex items-center gap-2">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 9V5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v4"/><path d="M2 11v5a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-5"/><path d="M2 11h20"/></svg>
                6 Hab.
              </span>
              <span class="flex items-center gap-2">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 6 6.5 3.5a1.5 1.5 0 0 0-1-.5C4.683 3 4 3.683 4 4.5V17a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-5"/><line x1="10" y1="5" x2="8" y2="7"/><line x1="2" y1="12" x2="22" y2="12"/></svg>
                7.5 Baños
              </span>
              <span class="flex items-center gap-2">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="1"/><path d="M3 9h18M9 21V9"/></svg>
                Luxury
              </span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       SERVICES TEASER
  ════════════════════════════════════════════════ -->
  <section class="py-24 md:py-32 bg-off-white" id="servicios" aria-label="Servicios">
    <div class="w-full max-w-7xl mx-auto px-6 md:px-12 xl:px-16">
      <div class="text-center fade-up max-w-2xl mx-auto mb-20">
        <p class="text-xs font-semibold tracking-[0.2em] uppercase text-gold mb-4" data-i18n="services-subtitle">Nuestros Servicios</p>
        <div class="w-12 h-0.5 bg-gold mx-auto mb-6"></div>
        <h2 class="font-serif text-3xl md:text-4xl lg:text-5xl text-navy" data-i18n="services-title">Soluciones Integrales de Construcción</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <!-- Interior Design -->
        <div class="fade-up bg-white p-10 rounded-xl shadow-lg shadow-navy/5 hover:-translate-y-2 hover:shadow-2xl transition-all duration-300 border border-mid/20 group">
          <div class="w-16 h-16 bg-off-white rounded-full flex items-center justify-center text-gold mb-8 group-hover:bg-gold group-hover:text-white transition-colors duration-300">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
            </svg>
          </div>
          <h3 class="font-serif text-xl text-navy mb-4" data-i18n="srv-interior-title">Diseño de Interiores</h3>
          <p class="text-muted mb-8 leading-relaxed text-sm" data-i18n="srv-interior-desc">Transformación total de apartamentos, penthouses y residencias con acabados de primera.</p>
          <a href="/services" class="text-gold font-medium hover:text-navy transition-colors text-sm flex items-center gap-2" data-i18n="srv-learn-more">Saber más <span>&rarr;</span></a>
        </div>
        <!-- Construction -->
        <div class="fade-up bg-white p-10 rounded-xl shadow-lg shadow-navy/5 hover:-translate-y-2 hover:shadow-2xl transition-all duration-300 border border-mid/20 group" style="animation-delay: 100ms">
          <div class="w-16 h-16 bg-off-white rounded-full flex items-center justify-center text-gold mb-8 group-hover:bg-gold group-hover:text-white transition-colors duration-300">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>
            </svg>
          </div>
          <h3 class="font-serif text-xl text-navy mb-4" data-i18n="srv-civil-title">Construcción &amp; Ampliaciones</h3>
          <p class="text-muted mb-8 leading-relaxed text-sm" data-i18n="srv-civil-desc">Estructuras residenciales y comerciales sólidas, cumpliendo todas las normas vigentes.</p>
          <a href="/services" class="text-gold font-medium hover:text-navy transition-colors text-sm flex items-center gap-2" data-i18n="srv-learn-more">Saber más <span>&rarr;</span></a>
        </div>
        <!-- Woodwork -->
        <div class="fade-up bg-white p-10 rounded-xl shadow-lg shadow-navy/5 hover:-translate-y-2 hover:shadow-2xl transition-all duration-300 border border-mid/20 group" style="animation-delay: 200ms">
          <div class="w-16 h-16 bg-off-white rounded-full flex items-center justify-center text-gold mb-8 group-hover:bg-gold group-hover:text-white transition-colors duration-300">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
            </svg>
          </div>
          <h3 class="font-serif text-xl text-navy mb-4" data-i18n="srv-wood-title">Ebanistería a Medida</h3>
          <p class="text-muted mb-8 leading-relaxed text-sm" data-i18n="srv-wood-desc">Cocinas modulares, clósets y mobiliario con maderas preciosas y herrajes premium.</p>
          <a href="/services" class="text-gold font-medium hover:text-navy transition-colors text-sm flex items-center gap-2" data-i18n="srv-learn-more">Saber más <span>&rarr;</span></a>
        </div>
        <!-- Project Management -->
        <div class="fade-up bg-white p-10 rounded-xl shadow-lg shadow-navy/5 hover:-translate-y-2 hover:shadow-2xl transition-all duration-300 border border-mid/20 group" style="animation-delay: 300ms">
          <div class="w-16 h-16 bg-off-white rounded-full flex items-center justify-center text-gold mb-8 group-hover:bg-gold group-hover:text-white transition-colors duration-300">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>
            </svg>
          </div>
          <h3 class="font-serif text-xl text-navy mb-4" data-i18n="srv-project-title">Gestión de Obra</h3>
          <p class="text-muted mb-8 leading-relaxed text-sm" data-i18n="srv-project-desc">Planificación rigurosa, compras, control de presupuesto y supervisión técnica constante.</p>
          <a href="/services" class="text-gold font-medium hover:text-navy transition-colors text-sm flex items-center gap-2" data-i18n="srv-learn-more">Saber más <span>&rarr;</span></a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       ABOUT STRIP
  ════════════════════════════════════════════════ -->
  <section class="py-24 md:py-32" id="nosotros" aria-label="Sobre nosotros">
    <div class="w-full max-w-7xl mx-auto px-6 md:px-12 xl:px-16">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="fade-up relative">
          <img src="/assets/images/projects/rodriguez-ii-2.webp" alt="Constructora Rodríguez Javier" class="rounded-xl shadow-2xl" loading="lazy">
          <div class="absolute -bottom-8 -right-8 bg-gold text-white p-8 rounded-xl shadow-xl hidden md:flex flex-col items-center text-center max-w-[200px]">
            <strong class="font-serif text-5xl mb-2">15</strong>
            <span class="text-sm font-semibold uppercase tracking-wider" data-i18n="stat-experience">Años de Exp.</span>
          </div>
        </div>
        <div class="fade-up lg:pl-10">
          <p class="text-xs font-semibold tracking-[0.2em] uppercase text-gold mb-4" data-i18n="about-subtitle">Sobre Nosotros</p>
          <div class="w-12 h-0.5 bg-gold mb-6"></div>
          <h2 class="font-serif text-3xl md:text-4xl text-navy mb-8" data-i18n="about-title">Más de 15 Años de Excelencia en Santo Domingo</h2>
          <p class="text-muted leading-relaxed mb-4 text-lg" data-i18n="about-p1">En Constructora Rodríguez Javier nos enorgullece ofrecer servicios de remodelación y construcción que superan las expectativas de nuestros clientes.</p>
          <p class="text-muted leading-relaxed mb-10 text-lg" data-i18n="about-p2">Utilizamos materiales de la más alta calidad y un equipo de artesanos, diseñadores e ingenieros calificados para asegurar que cada detalle sea impecable.</p>
          
          <div class="grid grid-cols-3 gap-6 mb-10 border-t border-b border-mid/40 py-8">
            <div>
              <strong class="block font-serif text-3xl text-navy mb-1">120+</strong>
              <span class="text-xs font-medium uppercase tracking-wider text-muted" data-i18n="stat-projects">Proyectos</span>
            </div>
            <div>
              <strong class="block font-serif text-3xl text-navy mb-1">98%</strong>
              <span class="text-xs font-medium uppercase tracking-wider text-muted" data-i18n="stat-satisfaction">Satisfacción</span>
            </div>
            <div>
              <strong class="block font-serif text-3xl text-navy mb-1">RD+USA</strong>
              <span class="text-xs font-medium uppercase tracking-wider text-muted" data-i18n="hero-stat-reach">Cobertura</span>
            </div>
          </div>
          <a href="/about" class="btn-primary" data-i18n="about-cta">Conoce el Equipo</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       TESTIMONIALS
  ════════════════════════════════════════════════ -->
  <section class="py-24 md:py-32 bg-off-white" aria-label="Testimonios">
    <div class="w-full max-w-7xl mx-auto px-6 md:px-12 xl:px-16">
      <div class="text-center fade-up max-w-2xl mx-auto mb-20">
        <p class="text-xs font-semibold tracking-[0.2em] uppercase text-gold mb-4" data-i18n="testi-subtitle">Testimonios</p>
        <div class="w-12 h-0.5 bg-gold mx-auto mb-6"></div>
        <h2 class="font-serif text-3xl md:text-4xl text-navy" data-i18n="testi-title">Lo que Dicen Nuestros Clientes</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="fade-up bg-white p-10 rounded-xl shadow-lg shadow-navy/5 border border-mid/20 relative">
          <div class="text-gold text-2xl mb-6 tracking-[0.2em]">★★★★★</div>
          <p class="text-muted leading-relaxed mb-8 italic" data-i18n="testi-1-text">«La remodelación de nuestra cocina en Naco fue una experiencia increíble. Cumplieron exactamente con el presupuesto y el tiempo de entrega.»</p>
          <div>
            <p class="font-bold text-navy" data-i18n="testi-1-author">Laura Guzmán</p>
            <p class="text-sm text-gold mt-1" data-i18n="testi-1-loc">Naco, Santo Domingo</p>
          </div>
        </div>
        <div class="fade-up bg-white p-10 rounded-xl shadow-lg shadow-navy/5 border border-mid/20 relative" style="animation-delay: 100ms">
          <div class="text-gold text-2xl mb-6 tracking-[0.2em]">★★★★★</div>
          <p class="text-muted leading-relaxed mb-8 italic" data-i18n="testi-2-text">«Profesionales de verdad. Hicieron una remodelación completa de nuestro penthouse en Bella Vista. Su atención al detalle es de otro nivel.»</p>
          <div>
            <p class="font-bold text-navy" data-i18n="testi-2-author">Ing. Carlos Mendoza</p>
            <p class="text-sm text-gold mt-1" data-i18n="testi-2-loc">Bella Vista, Santo Domingo</p>
          </div>
        </div>
        <div class="fade-up bg-white p-10 rounded-xl shadow-lg shadow-navy/5 border border-mid/20 relative" style="animation-delay: 200ms">
          <div class="text-gold text-2xl mb-6 tracking-[0.2em]">★★★★★</div>
          <p class="text-muted leading-relaxed mb-8 italic" data-i18n="testi-3-text">«Transformaron nuestra oficina en Piantini en un espacio moderno que asombra a nuestros clientes. Altamente recomendados.»</p>
          <div>
            <p class="font-bold text-navy" data-i18n="testi-3-author">Dra. Sofía Herrera</p>
            <p class="text-sm text-gold mt-1" data-i18n="testi-3-loc">Piantini, Santo Domingo</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       CTA BANNER
  ════════════════════════════════════════════════ -->
