---
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const SUPA_URL = 'https://kvxcnuckuxoemcfgkhau.supabase.co';
  const SUPA_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Imt2eGNudWNrdXhvZW1jZmdraGF1Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODM4MTA5NjksImV4cCI6MjA5OTM4Njk2OX0.tFmj4dTF7VaKCbGFtpt6AMMTYVoVDaj8y4emxtgrRhc';
  
  try {
    const res = await fetch(SUPA_URL + '/rest/v1/properties?select=*', {
      headers: { 'apikey': SUPA_KEY, 'Authorization': `Bearer ${SUPA_KEY}` }
    });
    
    if (!res.ok) return [];
    
    const properties = await res.json();
    
    return properties.map((prop: any) => {
      let image = "https://e0a90387.constructora-rodriguez-javier.pages.dev/assets/images/hero/hero-bg.webp";
      if (prop.image_urls && prop.image_urls.length > 0) {
        if (prop.image_urls[0].startsWith('http')) {
          image = prop.image_urls[0];
        } else if (prop.image_urls[0].startsWith('/assets/')) {
          image = "https://www.tucasard.com" + prop.image_urls[0];
        } else {
          image = SUPA_URL + '/storage/v1/object/public/property-images/' + (prop.image_urls[0].startsWith('/') ? prop.image_urls[0].substring(1) : prop.image_urls[0]);
        }
      }
      
      let description = "Descubre esta increíble propiedad de Constructora Rodríguez Javier.";
      let rawDesc = prop.description?.es || prop.description || "";
      if (typeof rawDesc === 'string' && rawDesc.trim().length > 0) {
          description = rawDesc.replace(/<[^>]*>?/gm, '').substring(0, 160) + '...';
      }

      let titleStr = prop.title?.es || prop.title || 'Detalle de Propiedad';
      
      let pageId = prop.slug || prop.id.toString();
      
      return {
        params: { id: pageId },
        props: {
          title: `Constructora Rodríguez Javier | ${titleStr}`,
          description,
          image,
          url: `https://www.tucasard.com/proyecto/${pageId}`
        }
      };
    });
  } catch (error) {
    console.error("Error in getStaticPaths:", error);
    return [];
  }
}

const { title, description, image, url } = Astro.props;
---

<Layout title={title} navTheme="light" description={description} image={image} url={url}>

  <main class="pt-24 pb-24 md:pt-32 md:pb-32 bg-off-white min-h-screen">
    <section aria-label="Detalle del proyecto">
      <div class="w-full max-w-7xl mx-auto px-4 sm:px-6 md:px-8 lg:px-12 xl:px-16">

        <!-- Breadcrumb -->
        <nav class="flex flex-wrap items-center gap-2 text-sm text-muted mb-8" aria-label="Breadcrumb">
          <a href="/" class="hover:text-gold transition-colors">Inicio</a>
          <span class="text-mid">/</span>
          <a href="/properties" class="hover:text-gold transition-colors">Propiedades</a>
          <span class="text-mid">/</span>
          <span id="detail-title" class="text-navy font-medium">Cargando...</span>
        </nav>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-10 items-start">

          <!-- ════════════════ MAIN COLUMN ════════════════ -->
          <div class="lg:col-span-2 space-y-6">

            <!-- Carousel -->
            <div class="bg-white rounded-2xl shadow-xl overflow-hidden">
              <div class="relative h-[380px] md:h-[520px] w-full bg-navy/5" id="detail-carousel">
                <img src="/assets/images/projects/duran-2.webp" alt="Cargando..." class="w-full h-full object-cover">
              </div>
              <div class="flex gap-3 overflow-x-auto p-4 bg-off-white border-t border-mid/20 scrollbar-hide" id="detail-thumbs"></div>
            </div>

            <!-- Header info -->
            <div class="bg-white rounded-2xl shadow-xl p-8 md:p-10">

              <!-- Status badge + type -->
              <div class="flex items-center gap-3 flex-wrap mb-3">
                <div id="detail-badge"></div>
                <span id="detail-type" class="text-xs bg-gray-100 text-gray-600 px-3 py-1 rounded-full font-medium hidden"></span>
              </div>

              <p class="text-gold font-medium text-sm tracking-wide uppercase mb-2" id="detail-location"></p>
              <h1 class="font-serif text-3xl md:text-4xl lg:text-5xl text-navy mb-6 leading-tight" id="detail-title-h1">Cargando...</h1>

              <!-- Price row -->
              <div class="flex flex-wrap items-baseline gap-6 mb-8 pb-6 border-b border-mid/20">
                <div>
                  <p class="text-xs text-muted uppercase tracking-wider mb-1">Precio</p>
                  <p class="font-serif text-3xl text-navy font-bold" id="detail-price-inline">—</p>
                </div>
                <div id="price-per-m2-block" class="hidden">
                  <p class="text-xs text-muted uppercase tracking-wider mb-1">Precio por m²</p>
                  <p class="font-serif text-xl text-gold" id="detail-price-m2">—</p>
                </div>
              </div>

              <!-- Tags -->
              <div id="detail-tags-container" class="mb-8 hidden">
                <div id="detail-tags" class="flex flex-wrap gap-2"></div>
              </div>

              <!-- ── SPECS GRID ── -->
              <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4 mb-8">
                <!-- M2 -->
                <div id="spec-m2" class="bg-off-white rounded-xl p-4 text-center hidden">
                  <p class="text-xl font-serif text-navy font-bold" id="detail-m2">—</p>
                  <p class="text-xs text-muted uppercase tracking-wider mt-1">m² Construidos</p>
                </div>
                <!-- Solar -->
                <div id="spec-solar" class="bg-off-white rounded-xl p-4 text-center hidden">
                  <p class="text-xl font-serif text-navy font-bold" id="detail-solar">—</p>
                  <p class="text-xs text-muted uppercase tracking-wider mt-1">m² Solar</p>
                </div>
                <!-- Beds -->
                <div id="spec-beds" class="bg-off-white rounded-xl p-4 text-center hidden">
                  <p class="text-xl font-serif text-navy font-bold" id="detail-beds">—</p>
                  <p class="text-xs text-muted uppercase tracking-wider mt-1">Habitaciones</p>
                </div>
                <!-- Baths -->
                <div id="spec-baths" class="bg-off-white rounded-xl p-4 text-center hidden">
                  <p class="text-xl font-serif text-navy font-bold" id="detail-baths">—</p>
                  <p class="text-xs text-muted uppercase tracking-wider mt-1">Baños</p>
                </div>
                <!-- Parking -->
                <div id="spec-park" class="bg-off-white rounded-xl p-4 text-center hidden">
                  <p class="text-xl font-serif text-navy font-bold" id="detail-park">—</p>
                  <p class="text-xs text-muted uppercase tracking-wider mt-1">Parqueos</p>
                </div>
                <!-- Floors -->
                <div id="spec-floors" class="bg-off-white rounded-xl p-4 text-center hidden">
                  <p class="text-xl font-serif text-navy font-bold" id="detail-floors">—</p>
                  <p class="text-xs text-muted uppercase tracking-wider mt-1">Niveles</p>
                </div>
                <!-- Year -->
                <div id="spec-year" class="bg-off-white rounded-xl p-4 text-center hidden">
                  <p class="text-xl font-serif text-navy font-bold" id="detail-year">—</p>
                  <p class="text-xs text-muted uppercase tracking-wider mt-1">Año construido</p>
                </div>
                <!-- HOA -->
                <div id="spec-hoa" class="bg-off-white rounded-xl p-4 text-center hidden">
                  <p class="text-xl font-serif text-navy font-bold" id="detail-hoa">—</p>
                  <p class="text-xs text-muted uppercase tracking-wider mt-1">HOA/Manto. mensual</p>
                </div>
              </div>

              <!-- ── AMENIDADES ── -->
              <div id="amenidades-block" class="hidden mb-8">
                <h3 class="font-serif text-xl text-navy mb-4 border-b border-mid/20 pb-2">✨ Amenidades</h3>
                <div id="detail-amenidades" class="flex flex-wrap gap-3"></div>
              </div>

              <!-- ── DESCRIPTION ── -->
              <h2 class="font-serif text-2xl text-navy mb-5 border-b border-mid/20 pb-3">📋 Descripción del Proyecto</h2>
              <div class="prose prose-navy max-w-none text-muted leading-relaxed" id="detail-desc">
                <p>Cargando descripción...</p>
              </div>
            </div>

          </div>

          <!-- ════════════════ SIDEBAR ════════════════ -->
          <aside class="lg:col-span-1 space-y-4 lg:sticky lg:top-28">

            <!-- Price card -->
            <div class="bg-white p-8 rounded-2xl shadow-2xl border border-mid/10">
              <p class="text-xs font-semibold tracking-[0.2em] uppercase text-muted mb-2" data-i18n="price-label">Precio Desde</p>
              <p class="font-serif text-3xl md:text-4xl text-navy mb-1 font-bold" id="detail-price">—</p>
              <p id="sidebar-price-m2" class="text-sm text-muted mb-6 hidden">
                <span id="sidebar-price-m2-val"></span> USD/m²
              </p>

              <!-- WhatsApp CTA -->
              <a id="wa-link" href="https://wa.me/16468831869?text=Hola%2C%20me%20interesa%20esta%20propiedad."
                target="_blank" rel="noopener"
                class="w-full justify-center mb-3 gap-2 flex items-center bg-navy hover:bg-navy/90 text-white px-6 py-3 rounded text-sm font-bold tracking-wider transition-colors">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-2 12H6v-2h12v2zm0-3H6V9h12v2zm0-3H6V6h12v2z"/>
                </svg>
                <span data-i18n="side-btn">Contactar por WhatsApp</span>
              </a>
              <a href="/contact" class="btn-outline w-full justify-center flex items-center mb-6" data-i18n="nav-cta">Cotizar Gratis</a>

              <hr class="my-6 border-mid/20">

              <!-- Property quick stats — rows start hidden, shown by app.js only when data exists -->
              <div class="space-y-3 mb-6" id="sidebar-stats">
                <div class="hidden flex justify-between items-center text-sm" id="sb-type-row">
                  <span class="text-muted" data-i18n="sb-type">Tipo</span>
                  <span class="text-navy font-medium" id="sidebar-type"></span>
                </div>
                <div class="hidden flex justify-between items-center text-sm" id="sb-year-row">
                  <span class="text-muted" data-i18n="sb-year">Año construido</span>
                  <span class="text-navy font-medium" id="sidebar-year"></span>
                </div>
                <div class="hidden flex justify-between items-center text-sm" id="sb-m2-row">
                  <span class="text-muted" data-i18n="sb-m2">Área construida</span>
                  <span class="text-navy font-medium" id="sidebar-m2"></span>
                </div>
                <div class="hidden flex justify-between items-center text-sm" id="sb-solar-row">
                  <span class="text-muted" data-i18n="sb-solar">Tamaño solar</span>
                  <span class="text-navy font-medium" id="sidebar-solar"></span>
                </div>
                <div class="hidden flex justify-between items-center text-sm" id="sb-hoa-row">
                  <span class="text-muted" data-i18n="sb-hoa">Mantenimiento</span>
                  <span class="text-navy font-medium" id="sidebar-hoa-val"></span>
                </div>
              </div>

            </div>

            <!-- Google Maps embed placeholder -->
            <div id="map-block" class="hidden bg-white rounded-2xl shadow-xl overflow-hidden border border-mid/10 mb-6 mt-6">
              <div class="px-5 py-4 border-b border-mid/10 bg-white">
                <p class="text-sm font-bold text-navy uppercase tracking-wider flex items-center gap-2"><span class="text-red-600">📍</span> <span data-i18n="map-title">Ubicación</span></p>
              </div>
              <a id="map-link" href="#" target="_blank" rel="noopener"
                class="block h-48 bg-[#aeb6c1] relative overflow-hidden flex items-center justify-center group hover:bg-[#9fa8b5] transition-colors">
                <span class="text-white font-semibold text-lg flex items-center gap-2 drop-shadow-md"><span data-i18n="map-btn">Ver en Google Maps</span> &rarr;</span>
              </a>
            </div>

            <!-- Back link -->
            <a href="/properties"
              class="flex items-center justify-center w-full py-4 px-6 bg-[#FAFAFA] text-navy border border-mid/20 rounded-xl font-medium hover:border-gold hover:text-gold transition-colors text-base shadow-sm">
              &larr; <span data-i18n="back-listings">Volver a Propiedades</span>
            </a>
          </aside>

        </div>
      </div>
    </section>
  </main>

</Layout>
