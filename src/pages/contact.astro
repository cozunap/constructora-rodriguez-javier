---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Constructora Rodríguez Javier | Contacto">
<!-- Nav injected -->

  <!-- ── Page Hero ─────────────────────────────── -->
  <div class="page-hero">
    <div class="container">
      <p class="overline" data-i18n="contact-subtitle">Contáctanos</p>
      <h1 data-i18n="contact-title">Hablemos de Tu Proyecto</h1>
      <p data-i18n="contact-desc">Completa el formulario para agendar una visita técnica sin costo en la zona metropolitana de Santo Domingo.</p>
    </div>
  </div>

  <!-- ── Contact Layout ─────────────────────────── -->
  <section class="section" aria-label="Información de contacto y formulario">
    <div class="container">
      <div class="contact-layout">

        <!-- Info -->
        <div class="contact-info fade-up">
          <p class="overline" style="margin-bottom:.75rem">Información de Contacto</p>
          <div class="gold-line"></div>
          <h2>Estamos aquí para ayudarte</h2>

          <div class="contact-detail">
            <div class="contact-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.56 1.37h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </div>
            <div class="contact-detail-text">
              <strong>Teléfono / WhatsApp</strong>
              <a href="tel:+18299595350">+1 (829) 959-5350</a>
            </div>
          </div>

          <div class="contact-detail">
            <div class="contact-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <div class="contact-detail-text">
              <strong>Email</strong>
              <a href="mailto:info@crjavier.com">info@crjavier.com</a>
            </div>
          </div>

          <div class="contact-detail">
            <div class="contact-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div class="contact-detail-text">
              <strong>Ubicación</strong>
              <p>Prado Oriental, Santo Domingo Este,<br>República Dominicana</p>
            </div>
          </div>

          <div class="contact-detail">
            <div class="contact-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <div class="contact-detail-text">
              <strong>Horario</strong>
              <p>Lun–Vie: 8:00 AM – 6:00 PM<br>Sáb: 9:00 AM – 1:00 PM</p>
            </div>
          </div>

          <div style="margin-top:2rem;padding-top:2rem;border-top:1px solid var(--mid)">
            <p class="overline" style="margin-bottom:1rem">Coordinación Remota</p>
            <p style="font-size:.875rem;color:var(--muted);line-height:1.7">¿Vives en Nueva York, Miami o cualquier otro estado de EE.UU.? Ofrecemos coordinación 100% digital vía WhatsApp, Zoom y correo electrónico.</p>
            <a href="https://wa.me/18299595350?text=Hola%2C%20me%20interesa%20cotizar%20un%20proyecto." target="_blank" class="btn btn-primary mt-3">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" style="margin-right:.35rem"><path d="M12.012 2c-5.506 0-9.988 4.482-9.988 9.988 0 1.76.459 3.473 1.332 4.978L2 22l5.234-1.373a9.927 9.927 0 0 0 4.778 1.217c5.506 0 9.988-4.482 9.988-9.988C22 6.482 17.518 2 12.012 2z"/></svg>
              Escribir por WhatsApp
            </a>
          </div>
        </div>

        <!-- Form -->
        <div class="form-card fade-up">
          <h3 data-i18n="contact-title">Cuéntanos sobre tu Proyecto</h3>
          <form id="contact-form" novalidate>
            <div class="form-grid">
              <div class="form-group">
                <label for="fname" data-i18n="form-name">Nombre Completo</label>
                <input type="text" id="fname" name="name" required autocomplete="name" placeholder="Tu nombre completo">
              </div>
              <div class="form-group">
                <label for="femail" data-i18n="form-email">Correo Electrónico</label>
                <input type="email" id="femail" name="email" required autocomplete="email" placeholder="correo@ejemplo.com">
              </div>
              <div class="form-group">
                <label for="fphone" data-i18n="form-phone">Teléfono</label>
                <input type="tel" id="fphone" name="phone" autocomplete="tel" placeholder="+1 (829) 000-0000">
              </div>
              <div class="form-group">
                <label for="fservice" data-i18n="form-service">Servicio de Interés</label>
                <select id="fservice" name="service" required>
                  <option value="" disabled selected data-i18n="form-service-select">Selecciona un servicio...</option>
                  <option value="kitchen" data-i18n="form-service-kitchen">Remodelación de Cocina</option>
                  <option value="bathroom" data-i18n="form-service-bathroom">Remodelación de Baño</option>
                  <option value="full" data-i18n="form-service-full">Remodelación Completa</option>
                  <option value="new" data-i18n="form-service-new">Construcción Nueva</option>
                  <option value="property">Compra de Propiedad</option>
                </select>
              </div>
              <div class="form-group full">
                <label for="fmessage" data-i18n="form-msg">Tu Proyecto</label>
                <textarea id="fmessage" name="message" rows="5" required placeholder="Cuéntanos sobre tu proyecto, ubicación, presupuesto aproximado..."></textarea>
              </div>
            </div>
            <button type="submit" class="btn btn-primary mt-3" style="width:100%;justify-content:center" id="form-submit">
              <span data-i18n="form-btn">Enviar Solicitud</span>
            </button>
          </form>
          <div class="form-success-msg" id="form-success" data-i18n="form-success">
            ✓ ¡Mensaje enviado! Nos pondremos en contacto contigo en breve.
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Footer injected -->

  
</Layout>
