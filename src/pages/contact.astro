---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Constructora Rodríguez Javier | Contacto">
  <!-- Nav injected -->

  <!-- ── Page Hero ─────────────────────────────── -->
  <div class="pt-32 pb-20 md:pt-40 md:pb-28 bg-navy text-center relative overflow-hidden">
    <div class="absolute inset-0 z-0 opacity-20 mix-blend-overlay">
      <img src="/assets/images/projects/duran-1.webp" alt="Background" class="w-full h-full object-cover">
    </div>
    <div class="w-full max-w-4xl mx-auto px-6 relative z-10">
      <p class="text-xs md:text-sm font-semibold tracking-[0.2em] uppercase text-gold mb-6" data-i18n="contact-subtitle">Contáctanos</p>
      <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl text-white leading-tight" data-i18n="contact-title">Hablemos de Tu Proyecto</h1>
      <p class="text-lg text-white/80 mt-6 max-w-2xl mx-auto" data-i18n="contact-desc">Completa el formulario para agendar una visita técnica sin costo en la zona metropolitana de Santo Domingo.</p>
    </div>
  </div>

  <!-- ── Contact Layout ─────────────────────────── -->
  <section class="py-24 md:py-32 bg-off-white" aria-label="Información de contacto y formulario">
    <div class="w-full max-w-7xl mx-auto px-6 md:px-12 xl:px-16">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-24 items-start">

        <!-- Info -->
        <div class="fade-up">
          <p class="text-xs font-semibold tracking-[0.2em] uppercase text-gold mb-4" data-i18n="contact-info-title">Información de Contacto</p>
          <div class="w-12 h-0.5 bg-gold mb-8"></div>
          <h2 class="font-serif text-3xl md:text-4xl text-navy mb-12" data-i18n="contact-help-title">Estamos aquí para ayudarte</h2>

          <div class="space-y-8">
            <div class="flex items-start gap-6">
              <div class="w-12 h-12 rounded-full bg-navy flex items-center justify-center text-gold shrink-0">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.56 1.37h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              </div>
              <div>
                <strong class="block text-navy font-bold mb-1" data-i18n="contact-phone">Teléfono / WhatsApp</strong>
                <a href="tel:+18299595350" class="text-muted hover:text-gold transition-colors">+1 (829) 959-5350</a>
              </div>
            </div>

            <div class="flex items-start gap-6">
              <div class="w-12 h-12 rounded-full bg-navy flex items-center justify-center text-gold shrink-0">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              </div>
              <div>
                <strong class="block text-navy font-bold mb-1" data-i18n="contact-email">Email</strong>
                <a href="mailto:info@crjavier.com" class="text-muted hover:text-gold transition-colors">info@crjavier.com</a>
              </div>
            </div>

            <div class="flex items-start gap-6">
              <div class="w-12 h-12 rounded-full bg-navy flex items-center justify-center text-gold shrink-0">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <div>
                <strong class="block text-navy font-bold mb-1" data-i18n="contact-location">Ubicación</strong>
                <p class="text-muted" data-i18n="contact-address">Prado Oriental, Santo Domingo Este,<br>República Dominicana</p>
              </div>
            </div>

            <div class="flex items-start gap-6">
              <div class="w-12 h-12 rounded-full bg-navy flex items-center justify-center text-gold shrink-0">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              </div>
              <div>
                <strong class="block text-navy font-bold mb-1" data-i18n="contact-hours">Horario</strong>
                <p class="text-muted" data-i18n="contact-hours-desc">Lun–Vie: 8:00 AM – 6:00 PM<br>Sáb: 9:00 AM – 1:00 PM</p>
              </div>
            </div>
          </div>

          <div class="mt-12 pt-10 border-t border-mid/30">
            <p class="text-xs font-semibold tracking-[0.2em] uppercase text-gold mb-4" data-i18n="contact-remote">Coordinación Remota</p>
            <p class="text-sm text-muted leading-relaxed mb-6" data-i18n="contact-remote-desc">¿Vives en Nueva York, Miami o cualquier otro estado de EE.UU.? Ofrecemos coordinación 100% digital vía WhatsApp, Zoom y correo electrónico.</p>
            <a href="https://wa.me/18299595350?text=Hola%2C%20me%20interesa%20cotizar%20un%20proyecto." target="_blank" class="btn-primary inline-flex items-center gap-2">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12.012 2c-5.506 0-9.988 4.482-9.988 9.988 0 1.76.459 3.473 1.332 4.978L2 22l5.234-1.373a9.927 9.927 0 0 0 4.778 1.217c5.506 0 9.988-4.482 9.988-9.988C22 6.482 17.518 2 12.012 2z"/></svg>
              <span data-i18n="contact-whatsapp-btn">Escribir por WhatsApp</span>
            </a>
          </div>
        </div>

        <!-- Form -->
        <div class="fade-up bg-white p-8 md:p-10 rounded-xl shadow-2xl shadow-navy/5 border border-mid/20">
          <h3 class="font-serif text-3xl text-navy mb-8" data-i18n="contact-title">Cuéntanos sobre tu Proyecto</h3>
          <form id="contact-form" novalidate class="space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class="space-y-2">
                <label for="fname" class="block text-xs font-bold text-navy uppercase tracking-[0.1em]" data-i18n="form-name">Nombre Completo</label>
                <input type="text" id="fname" name="name" required autocomplete="name" placeholder="Tu nombre completo" class="w-full bg-transparent border-0 border-b border-mid/40 rounded-none px-0 py-3 focus:outline-none focus:ring-0 focus:border-gold transition-colors text-navy placeholder:text-muted/50 text-lg">
              </div>
              <div class="space-y-2">
                <label for="femail" class="block text-xs font-bold text-navy uppercase tracking-[0.1em]" data-i18n="form-email">Correo Electrónico</label>
                <input type="email" id="femail" name="email" required autocomplete="email" placeholder="correo@ejemplo.com" class="w-full bg-transparent border-0 border-b border-mid/40 rounded-none px-0 py-3 focus:outline-none focus:ring-0 focus:border-gold transition-colors text-navy placeholder:text-muted/50 text-lg">
              </div>
              <div class="space-y-2">
                <label for="fphone" class="block text-xs font-bold text-navy uppercase tracking-[0.1em]" data-i18n="form-phone">Teléfono</label>
                <input type="tel" id="fphone" name="phone" autocomplete="tel" placeholder="+1 (829) 000-0000" class="w-full bg-transparent border-0 border-b border-mid/40 rounded-none px-0 py-3 focus:outline-none focus:ring-0 focus:border-gold transition-colors text-navy placeholder:text-muted/50 text-lg">
              </div>
              <div class="space-y-2">
                <label for="fservice" class="block text-xs font-bold text-navy uppercase tracking-[0.1em]" data-i18n="form-service">Servicio de Interés</label>
                <select id="fservice" name="service" required class="w-full bg-transparent border-0 border-b border-mid/40 rounded-none px-0 py-3 focus:outline-none focus:ring-0 focus:border-gold transition-colors text-navy appearance-none cursor-pointer text-lg">
                  <option value="" disabled selected data-i18n="form-service-select">Selecciona un servicio...</option>
                  <option value="kitchen" data-i18n="form-service-kitchen">Remodelación de Cocina</option>
                  <option value="bathroom" data-i18n="form-service-bathroom">Remodelación de Baño</option>
                  <option value="full" data-i18n="form-service-full">Remodelación Completa</option>
                  <option value="new" data-i18n="form-service-new">Construcción Nueva</option>
                  <option value="property">Compra de Propiedad</option>
                </select>
              </div>
              <div class="space-y-2 md:col-span-2">
                <label for="fmessage" class="block text-xs font-bold text-navy uppercase tracking-[0.1em]" data-i18n="form-msg">Tu Proyecto</label>
                <textarea id="fmessage" name="message" rows="4" required placeholder="Cuéntanos sobre tu proyecto, ubicación, presupuesto aproximado..." class="w-full bg-transparent border-0 border-b border-mid/40 rounded-none px-0 py-3 focus:outline-none focus:ring-0 focus:border-gold transition-colors text-navy placeholder:text-muted/50 resize-y text-lg"></textarea>
              </div>
            </div>
            <button type="submit" class="btn-primary w-full justify-center mt-8" id="form-submit">
              <span data-i18n="form-btn">Enviar Solicitud</span>
            </button>
          </form>
          <div class="hidden mt-6 p-4 bg-green-50 text-green-800 rounded border border-green-200 text-center font-medium" id="form-success" data-i18n="form-success">
            ✓ ¡Mensaje enviado! Nos pondremos en contacto contigo en breve.
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Footer injected -->

</Layout>
