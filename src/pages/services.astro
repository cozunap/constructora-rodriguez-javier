---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';

const seoTitle = "Construcción, Ebanistería y Retorno de Inversión (ROI) en Bienes Raíces";
const seoDesc = "Servicios integrales de arquitectura, construcción y gestión de propiedades en República Dominicana. Asegure un alto retorno de inversión (ROI) con nuestros desarrollos de lujo.";
---

<Layout title={seoTitle} description={seoDesc}>
  <!-- Nav injected -->

  <!-- ── Page Hero ─────────────────────────────── -->
  <div class="pt-32 pb-20 md:pt-40 md:pb-28 bg-navy text-center relative overflow-hidden">
    <div class="absolute inset-0 z-0 opacity-20 mix-blend-overlay">
      <img src="/assets/images/projects/duran-1.webp" alt="Background" class="w-full h-full object-cover" fetchpriority="high">
    </div>
    <div class="w-full max-w-4xl mx-auto px-6 relative z-10">
      <p class="text-xs md:text-sm font-semibold tracking-[0.2em] uppercase text-gold mb-6" data-i18n="services-subtitle">Construcción & Inversión Inmobiliaria</p>
      <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl text-white leading-tight" data-i18n="services-title">Soluciones para Retorno de Inversión (ROI)</h1>
      <p class="text-lg text-white/80 mt-6 max-w-2xl mx-auto" data-i18n="services-desc">Expertos en diseño, remodelación y construcción de propiedades de lujo preparadas para alquiler vacacional y venta de terrenos en la costa.</p>
    </div>
  </div>

  <!-- ── Service Detail Blocks ─────────────────── -->
  <section class="py-24 md:py-32" aria-label="Detalle de servicios">
    <div class="w-full max-w-7xl mx-auto px-4 sm:px-6 md:px-8 lg:px-12 xl:px-16 space-y-24 md:space-y-32">

      <!-- Interior Design -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div class="fade-up order-2 lg:order-1 relative rounded-xl overflow-hidden shadow-2xl group">
          <div class="absolute inset-0 bg-navy/20 mix-blend-multiply group-hover:opacity-0 transition-opacity duration-500 z-10"></div>
          <img src="/assets/images/services/Interior%20Design%20%26%20Remodeling.webp" alt="Diseño de Interiores" class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-700" loading="lazy">
        </div>
        <div class="fade-up order-1 lg:order-2">
          <p class="text-xs font-semibold tracking-[0.2em] uppercase text-gold mb-4 text-left">01</p>
          <div class="w-12 h-0.5 bg-gold mb-6"></div>
          <h2 class="font-serif text-3xl md:text-4xl text-navy mb-6" data-i18n="srv-interior-title">Diseño de Interiores &amp; Remodelaciones</h2>
          <p class="text-lg text-muted leading-relaxed mb-8" data-i18n="srv-interior-desc">Transformación total de apartamentos, penthouses y residencias con acabados de primera.</p>
          <ul class="space-y-4 mb-8 text-muted">
            <li class="flex items-start gap-3" data-i18n="modal-srv-interior-desc">
              <span class="text-gold mt-1">✔</span> Diseño 3D realista antes de iniciar la obra física.
            </li>
            <li class="flex items-start gap-3" data-i18n="srv-feat-2">
              <span class="text-gold mt-1">✔</span> Cocinas de cuarzo y granito a medida
            </li>
            <li class="flex items-start gap-3" data-i18n="srv-feat-3">
              <span class="text-gold mt-1">✔</span> Baños tipo spa con porcelanato importado
            </li>
            <li class="flex items-start gap-3" data-i18n="srv-feat-4">
              <span class="text-gold mt-1">✔</span> Iluminación LED integrada en cornisas
            </li>
            <li class="flex items-start gap-3" data-i18n="srv-feat-5">
              <span class="text-gold mt-1">✔</span> Coordinación 100% remota disponible
            </li>
          </ul>
          <a href="/contact" class="btn-primary" data-i18n="nav-cta">Cotizar Gratis</a>
        </div>
      </div>

      <!-- Construction -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div class="fade-up">
          <p class="text-xs font-semibold tracking-[0.2em] uppercase text-gold mb-4 text-left">02</p>
          <div class="w-12 h-0.5 bg-gold mb-6"></div>
          <h2 class="font-serif text-3xl md:text-4xl text-navy mb-6" data-i18n="srv-civil-title">Construcción &amp; Ampliaciones</h2>
          <p class="text-lg text-muted leading-relaxed mb-8" data-i18n="srv-civil-desc">Estructuras residenciales y comerciales sólidas y seguras, cumpliendo con todas las normas vigentes.</p>
          <ul class="space-y-4 mb-8 text-muted">
            <li class="flex items-start gap-3" data-i18n="srv-feat-6">
              <span class="text-gold mt-1">✔</span> Construcciones residenciales desde cero
            </li>
            <li class="flex items-start gap-3" data-i18n="srv-feat-7">
              <span class="text-gold mt-1">✔</span> Ampliaciones de niveles y terrazas
            </li>
            <li class="flex items-start gap-3" data-i18n="srv-feat-8">
              <span class="text-gold mt-1">✔</span> Locales comerciales y oficinas
            </li>
            <li class="flex items-start gap-3" data-i18n="srv-feat-9">
              <span class="text-gold mt-1">✔</span> Supervisión técnica de ingenieros colegiados
            </li>
            <li class="flex items-start gap-3" data-i18n="srv-feat-10">
              <span class="text-gold mt-1">✔</span> Garantía estructural por escrito
            </li>
          </ul>
          <a href="/contact" class="btn-primary" data-i18n="nav-cta">Cotizar Gratis</a>
        </div>
        <div class="fade-up relative rounded-xl overflow-hidden shadow-2xl group">
          <div class="absolute inset-0 bg-navy/20 mix-blend-multiply group-hover:opacity-0 transition-opacity duration-500 z-10"></div>
          <img src="/assets/images/services/Construction%20%26%20Extensions.webp" alt="Construcción" class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-700" loading="lazy">
        </div>
      </div>

      <!-- Woodwork -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div class="fade-up order-2 lg:order-1 relative rounded-xl overflow-hidden shadow-2xl group">
          <div class="absolute inset-0 bg-navy/20 mix-blend-multiply group-hover:opacity-0 transition-opacity duration-500 z-10"></div>
          <img src="/assets/images/services/Custom%20Cabinetry%20%26%20Woodworking.webp" alt="Ebanistería" class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-700" loading="lazy">
        </div>
        <div class="fade-up order-1 lg:order-2">
          <p class="text-xs font-semibold tracking-[0.2em] uppercase text-gold mb-4 text-left">03</p>
          <div class="w-12 h-0.5 bg-gold mb-6"></div>
          <h2 class="font-serif text-3xl md:text-4xl text-navy mb-6" data-i18n="srv-wood-title">Ebanistería &amp; Diseños a Medida</h2>
          <p class="text-lg text-muted leading-relaxed mb-8" data-i18n="srv-wood-desc">Cocinas modulares, clósets y mobiliario hechos con maderas preciosas y herrajes premium.</p>
          <ul class="space-y-4 mb-8 text-muted">
            <li class="flex items-start gap-3" data-i18n="srv-feat-11">
              <span class="text-gold mt-1">✔</span> Cocinas modulares hidrófugas de alta durabilidad
            </li>
            <li class="flex items-start gap-3" data-i18n="srv-feat-12">
              <span class="text-gold mt-1">✔</span> Clósets en roble y maderas selectas
            </li>
            <li class="flex items-start gap-3" data-i18n="srv-feat-13">
              <span class="text-gold mt-1">✔</span> Puertas sólidas con acabado lacado
            </li>
            <li class="flex items-start gap-3" data-i18n="srv-feat-14">
              <span class="text-gold mt-1">✔</span> Muebles de baño a medida
            </li>
            <li class="flex items-start gap-3" data-i18n="srv-feat-15">
              <span class="text-gold mt-1">✔</span> Tiempo de entrega garantizado por contrato
            </li>
          </ul>
          <a href="/contact" class="btn-primary" data-i18n="nav-cta">Cotizar Gratis</a>
        </div>
      </div>

      <!-- Project Management -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div class="fade-up">
          <p class="text-xs font-semibold tracking-[0.2em] uppercase text-gold mb-4 text-left">04</p>
          <div class="w-12 h-0.5 bg-gold mb-6"></div>
          <h2 class="font-serif text-3xl md:text-4xl text-navy mb-6" data-i18n="srv-project-title">Gestión &amp; Dirección de Obra</h2>
          <p class="text-lg text-muted leading-relaxed mb-8" data-i18n="srv-project-desc">Planificación rigurosa, compras, control de presupuesto y supervisión técnica constante.</p>
          <ul class="space-y-4 mb-8 text-muted">
            <li class="flex items-start gap-3" data-i18n="srv-feat-16">
              <span class="text-gold mt-1">✔</span> Informes semanales con fotos y video
            </li>
            <li class="flex items-start gap-3" data-i18n="srv-feat-17">
              <span class="text-gold mt-1">✔</span> Compras directas a proveedores líderes
            </li>
            <li class="flex items-start gap-3" data-i18n="srv-feat-18">
              <span class="text-gold mt-1">✔</span> Control estricto de cronogramas
            </li>
            <li class="flex items-start gap-3" data-i18n="srv-feat-19">
              <span class="text-gold mt-1">✔</span> Gestión de permisos y documentación
            </li>
            <li class="flex items-start gap-3" data-i18n="srv-feat-20">
              <span class="text-gold mt-1">✔</span> Ideal para dominicanos residentes en USA
            </li>
          </ul>
          <a href="/contact" class="btn-primary" data-i18n="nav-cta">Cotizar Gratis</a>
        </div>
        <div class="fade-up relative rounded-xl overflow-hidden shadow-2xl group">
          <div class="absolute inset-0 bg-navy/20 mix-blend-multiply group-hover:opacity-0 transition-opacity duration-500 z-10"></div>
          <img src="/assets/images/services/Project%20Management%20%26%20Supervision.webp" alt="Gestión de Obra" class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-700" loading="lazy">
        </div>
      </div>

    </div>
  </section>

  <!-- ── Other Services ────────────────────────── -->
  <section class="py-24 bg-white" aria-label="Otros servicios especializados">
    <div class="w-full max-w-7xl mx-auto px-4 sm:px-6 md:px-8 lg:px-12 xl:px-16">
      <div class="text-center fade-up max-w-2xl mx-auto mb-16">
        <p class="text-xs font-semibold tracking-[0.2em] uppercase text-gold mb-4" data-i18n="srv-other-tag">Más Soluciones</p>
        <div class="w-12 h-0.5 bg-gold mx-auto mb-6"></div>
        <h2 class="font-serif text-3xl md:text-4xl text-navy" data-i18n="srv-other-title">Otros Servicios Especializados</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="fade-up bg-off-white p-6 rounded-xl border border-mid/20 flex items-start gap-4 hover:shadow-lg hover:border-gold/50 transition-all duration-300">
          <span class="text-gold mt-1">✔</span>
          <h3 class="font-serif text-lg text-navy leading-snug" data-i18n="srv-other-1">Análisis y Diseño Estructural Sismorresistente</h3>
        </div>
        <div class="fade-up bg-off-white p-6 rounded-xl border border-mid/20 flex items-start gap-4 hover:shadow-lg hover:border-gold/50 transition-all duration-300" style="animation-delay: 100ms">
          <span class="text-gold mt-1">✔</span>
          <h3 class="font-serif text-lg text-navy leading-snug" data-i18n="srv-other-2">Estudio de Vulnerabilidad Sísmica</h3>
        </div>
        <div class="fade-up bg-off-white p-6 rounded-xl border border-mid/20 flex items-start gap-4 hover:shadow-lg hover:border-gold/50 transition-all duration-300" style="animation-delay: 200ms">
          <span class="text-gold mt-1">✔</span>
          <h3 class="font-serif text-lg text-navy leading-snug" data-i18n="srv-other-3">Supervisión Estructural Certificada</h3>
        </div>
        <div class="fade-up bg-off-white p-6 rounded-xl border border-mid/20 flex items-start gap-4 hover:shadow-lg hover:border-gold/50 transition-all duration-300" style="animation-delay: 300ms">
          <span class="text-gold mt-1">✔</span>
          <h3 class="font-serif text-lg text-navy leading-snug" data-i18n="srv-other-4">Ingeniería Estructural Avanzada</h3>
        </div>
        <div class="fade-up bg-off-white p-6 rounded-xl border border-mid/20 flex items-start gap-4 hover:shadow-lg hover:border-gold/50 transition-all duration-300" style="animation-delay: 400ms">
          <span class="text-gold mt-1">✔</span>
          <h3 class="font-serif text-lg text-navy leading-snug" data-i18n="srv-other-5">Presupuesto y Tasación</h3>
        </div>
        <div class="fade-up bg-off-white p-6 rounded-xl border border-mid/20 flex items-start gap-4 hover:shadow-lg hover:border-gold/50 transition-all duration-300" style="animation-delay: 500ms">
          <span class="text-gold mt-1">✔</span>
          <h3 class="font-serif text-lg text-navy leading-snug" data-i18n="srv-other-6">Promotores de Inversiones e Inmobiliaria</h3>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Process ────────────────────────────────── -->
  <section class="py-24 md:py-32 bg-off-white" aria-label="Nuestro proceso">
    <div class="w-full max-w-7xl mx-auto px-4 sm:px-6 md:px-8 lg:px-12 xl:px-16">
      <div class="text-center fade-up max-w-2xl mx-auto mb-20">
        <p class="text-xs font-semibold tracking-[0.2em] uppercase text-gold mb-4" data-i18n="srv-proc-tag">Nuestro Proceso</p>
        <div class="w-12 h-0.5 bg-gold mx-auto mb-6"></div>
        <h2 class="font-serif text-3xl md:text-4xl text-navy" data-i18n="srv-proc-title">Simple. Transparente. Sin estrés.</h2>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-5 gap-8">
        <div class="fade-up bg-white p-8 rounded-xl shadow-lg shadow-navy/5 border border-mid/20 text-center relative group">
          <div class="w-12 h-12 bg-navy text-gold font-serif text-xl flex items-center justify-center rounded-full mx-auto mb-6 absolute -top-6 left-1/2 transform -translate-x-1/2 border-4 border-white">01</div>
          <h3 class="font-serif text-lg text-navy mb-4 mt-4" data-i18n="srv-proc-1-title">Consulta Inicial</h3>
          <p class="text-muted text-sm leading-relaxed" data-i18n="srv-proc-1-desc">Contacto por WhatsApp, Zoom o correo. Sin compromiso.</p>
        </div>
        <div class="fade-up bg-white p-8 rounded-xl shadow-lg shadow-navy/5 border border-mid/20 text-center relative group" style="animation-delay: 100ms">
          <div class="w-12 h-12 bg-navy text-gold font-serif text-xl flex items-center justify-center rounded-full mx-auto mb-6 absolute -top-6 left-1/2 transform -translate-x-1/2 border-4 border-white">02</div>
          <h3 class="font-serif text-lg text-navy mb-4 mt-4" data-i18n="srv-proc-2-title">Diseño en 3D</h3>
          <p class="text-muted text-sm leading-relaxed" data-i18n="srv-proc-2-desc">Visualiza tu proyecto antes de iniciar cualquier obra.</p>
        </div>
        <div class="fade-up bg-white p-8 rounded-xl shadow-lg shadow-navy/5 border border-mid/20 text-center relative group" style="animation-delay: 200ms">
          <div class="w-12 h-12 bg-navy text-gold font-serif text-xl flex items-center justify-center rounded-full mx-auto mb-6 absolute -top-6 left-1/2 transform -translate-x-1/2 border-4 border-white">03</div>
          <h3 class="font-serif text-lg text-navy mb-4 mt-4" data-i18n="srv-proc-3-title">Contrato Claro</h3>
          <p class="text-muted text-sm leading-relaxed" data-i18n="srv-proc-3-desc">Presupuesto fijo, cronograma y garantías por escrito.</p>
        </div>
        <div class="fade-up bg-white p-8 rounded-xl shadow-lg shadow-navy/5 border border-mid/20 text-center relative group" style="animation-delay: 300ms">
          <div class="w-12 h-12 bg-navy text-gold font-serif text-xl flex items-center justify-center rounded-full mx-auto mb-6 absolute -top-6 left-1/2 transform -translate-x-1/2 border-4 border-white">04</div>
          <h3 class="font-serif text-lg text-navy mb-4 mt-4" data-i18n="srv-proc-4-title">Ejecución &amp; Reportes</h3>
          <p class="text-muted text-sm leading-relaxed" data-i18n="srv-proc-4-desc">Supervisión semanal con fotos y video. Tú siempre informado.</p>
        </div>
        <div class="fade-up bg-white p-8 rounded-xl shadow-lg shadow-navy/5 border border-mid/20 text-center relative group" style="animation-delay: 400ms">
          <div class="w-12 h-12 bg-navy text-gold font-serif text-xl flex items-center justify-center rounded-full mx-auto mb-6 absolute -top-6 left-1/2 transform -translate-x-1/2 border-4 border-white">05</div>
          <h3 class="font-serif text-lg text-navy mb-4 mt-4" data-i18n="srv-proc-5-title">Entrega Llave en Mano</h3>
          <p class="text-muted text-sm leading-relaxed" data-i18n="srv-proc-5-desc">Tu espacio listo, impecable y con garantía incluida.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── CTA ────────────────────────────────────── -->
  <div class="relative py-24 md:py-32 bg-navy overflow-hidden" aria-label="Llamada a la acción">
    <div class="absolute inset-0 z-0 opacity-20 bg-[url('/assets/images/projects/duran-1.webp')] bg-cover bg-center"></div>
    <div class="absolute inset-0 bg-navy/90 z-0"></div>
    <div class="w-full max-w-7xl mx-auto px-4 sm:px-6 md:px-8 lg:px-12 xl:px-16 relative z-10 text-center">
      <p class="text-xs font-semibold tracking-[0.2em] uppercase text-gold mb-6" data-i18n="cta-overline">¿Listo para empezar?</p>
      <h2 class="font-serif text-4xl md:text-5xl text-white mb-6" data-i18n="cta-title">Hablemos de tu Proyecto</h2>
      <p class="text-lg text-white/80 max-w-2xl mx-auto mb-10" data-i18n="cta-desc">Coordinamos contigo desde donde estés — Nueva York, Miami, Madrid o Santo Domingo.</p>
      <div class="flex flex-wrap items-center justify-center gap-4">
        <a href="/contact" class="btn-gold" data-i18n="nav-cta">Cotizar Gratis</a>
        <a href="/properties" class="btn-outline-white" data-i18n="nav-properties">Ver Propiedades</a>
      </div>
    </div>
  </div>

  <!-- Footer injected -->
  
</Layout>
