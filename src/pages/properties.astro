---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Constructora Rodríguez Javier | Propiedades">
<!-- Nav injected by components.js -->

  <!-- ── Page Hero ─────────────────────────────── -->
  <div class="page-hero">
    <div class="container">
      <p class="overline" data-i18n="re-subtitle">Luxury Real Estate</p>
      <h1 data-i18n="re-title">Propiedades &amp; Proyectos</h1>
      <p data-i18n="re-desc">Descubre villas exclusivas, apartamentos de playa y proyectos residenciales premium en las mejores zonas de República Dominicana.</p>
    </div>
  </div>

  <!-- ── Listings ───────────────────────────────── -->
  <section class="section" aria-label="Listado de propiedades">
    <div class="container">

      <!-- Filter bar -->
      <div class="filter-bar" role="group" aria-label="Filtros">
        <button class="filter-btn active" data-filter="all" data-i18n="filter-all">Todas</button>
        <button class="filter-btn" data-filter="en_desarrollo" data-i18n="filter-dev">En Desarrollo</button>
        <button class="filter-btn" data-filter="disponible" data-i18n="filter-sale">En Venta</button>
      </div>

      <!-- Grid -->
      <div class="prop-grid" id="props-grid">
        <!-- Populated by app.js -->
      </div>
      <div class="no-results" id="no-results" style="display:none">
        <p data-i18n="no-results">No se encontraron propiedades con ese filtro.</p>
      </div>

    </div>
  </section>

  <!-- ── CTA ────────────────────────────────────── -->
  <div class="cta-banner">
    <div class="container">
      <p class="overline" data-i18n="cta-overline">¿Listo para empezar?</p>
      <h2 data-i18n="cta-title">Hablemos de tu Proyecto</h2>
      <p data-i18n="cta-desc">Coordinamos contigo desde donde estés — Nueva York, Miami, Madrid o Santo Domingo.</p>
      <div class="cta-banner-actions">
        <a href="/contact" class="btn btn-gold" data-i18n="nav-cta">Cotizar Gratis</a>
      </div>
    </div>
  </div>

  <!-- Footer injected by components.js -->

  
  
</Layout>
