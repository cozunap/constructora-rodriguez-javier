---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Constructora Rodríguez Javier | Proyecto" navTheme="light">
  <!-- Nav injected by Layout -->

  <main class="pt-24 pb-24 md:pt-32 md:pb-32 bg-off-white min-h-screen">
    <section aria-label="Detalle del proyecto">
      <div class="w-full max-w-7xl mx-auto px-6 md:px-12 xl:px-16">

        <!-- Breadcrumb -->
        <nav class="flex flex-wrap items-center gap-2 text-sm text-muted mb-8" aria-label="Breadcrumb">
          <a href="/" class="hover:text-gold transition-colors" data-i18n="nav-home">Inicio</a>
          <span class="text-mid">/</span>
          <a href="/properties" class="hover:text-gold transition-colors" data-i18n="nav-properties">Propiedades</a>
          <span class="text-mid">/</span>
          <span id="detail-title" class="text-navy font-medium">Cargando...</span>
        </nav>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 items-start">

          <!-- Main column -->
          <div class="lg:col-span-2 space-y-8">

            <!-- Carousel -->
            <div class="bg-white rounded-xl shadow-xl overflow-hidden mb-8">
              <div class="relative h-[400px] md:h-[550px] w-full bg-navy/5" id="detail-carousel">
                <img src="/assets/images/projects/duran-2.webp" alt="Cargando..." class="w-full h-full object-cover">
              </div>
              <div class="flex gap-4 overflow-x-auto p-4 md:p-6 bg-off-white scrollbar-hide border-t border-mid/20" id="detail-thumbs"></div>
            </div>

            <div class="bg-white p-8 md:p-12 rounded-xl shadow-xl">
              <!-- Title + Badge -->
              <div class="flex items-center gap-4 flex-wrap mb-4">
                <div id="detail-badge"></div>
              </div>
              <p class="text-gold font-medium text-sm tracking-wide uppercase mb-2" id="detail-location"></p>
              <h1 class="font-serif text-3xl md:text-4xl lg:text-5xl text-navy mb-8 leading-tight" id="detail-title-h1">Cargando...</h1>

              <!-- Specs strip -->
              <div class="grid grid-cols-2 md:grid-cols-4 gap-6 py-8 border-t border-b border-mid/30 mb-8">
                <div class="text-center md:text-left">
                  <strong class="block font-serif text-2xl text-navy mb-1" id="detail-m2">—</strong>
                  <span class="text-xs font-medium uppercase tracking-wider text-muted" data-i18n="spec-area">Área</span>
                </div>
                <div class="text-center md:text-left border-l md:border-l-0 border-mid/30 md:border-none pl-6 md:pl-0">
                  <strong class="block font-serif text-2xl text-navy mb-1" id="detail-beds">—</strong>
                  <span class="text-xs font-medium uppercase tracking-wider text-muted" data-i18n="spec-beds">Hab.</span>
                </div>
                <div class="text-center md:text-left">
                  <strong class="block font-serif text-2xl text-navy mb-1" id="detail-baths">—</strong>
                  <span class="text-xs font-medium uppercase tracking-wider text-muted" data-i18n="spec-baths">Baños</span>
                </div>
                <div class="text-center md:text-left border-l md:border-l-0 border-mid/30 md:border-none pl-6 md:pl-0">
                  <strong class="block font-serif text-2xl text-navy mb-1" id="detail-park">—</strong>
                  <span class="text-xs font-medium uppercase tracking-wider text-muted" data-i18n="spec-park">Parq.</span>
                </div>
              </div>

              <!-- Description -->
              <h2 class="font-serif text-2xl text-navy mb-4" data-i18n="description-title">Descripción del Proyecto</h2>
              <div class="prose prose-navy max-w-none text-muted leading-relaxed" id="detail-desc">
                <p>Cargando descripción...</p>
              </div>
            </div>

          </div>

          <!-- Sidebar -->
          <aside class="lg:col-span-1 sticky top-28">
            <div class="bg-white p-8 rounded-xl shadow-2xl border border-mid/20">
              <p class="text-xs font-semibold tracking-[0.2em] uppercase text-muted mb-2" data-i18n="price-label">Precio Desde</p>
              <p class="font-serif text-3xl md:text-4xl text-navy mb-8" id="detail-price">—</p>

              <a href="https://wa.me/18299595350?text=Hola%2C%20me%20interesa%20este%20proyecto." target="_blank" class="btn-primary w-full justify-center mb-4 gap-2">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12.012 2c-5.506 0-9.988 4.482-9.988 9.988 0 1.76.459 3.473 1.332 4.978L2 22l5.234-1.373a9.927 9.927 0 0 0 4.778 1.217c5.506 0 9.988-4.482 9.988-9.988C22 6.482 17.518 2 12.012 2z"/></svg>
                <span data-i18n="side-btn">Contactar por WhatsApp</span>
              </a>
              <a href="/contact" class="btn-outline w-full justify-center" data-i18n="nav-cta">Cotizar Gratis</a>

              <hr class="my-8 border-mid/30">

              <p class="font-semibold text-navy mb-2" data-i18n="side-title">¿Te interesa este proyecto?</p>
              <p class="text-sm text-muted leading-relaxed" data-i18n="side-desc">Contáctanos directamente por WhatsApp para recibir planos, brochure y agendar una visita.</p>

              <hr class="my-8 border-mid/30">

              <div class="flex items-center gap-4">
                <div class="w-10 h-10 rounded-full bg-off-white flex items-center justify-center text-navy shrink-0 border border-mid/20">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.56 1.37h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                </div>
                <div>
                  <strong class="block text-navy font-bold">+1 (829) 959-5350</strong>
                  <span class="text-xs text-muted uppercase tracking-wider">WhatsApp / Tel.</span>
                </div>
              </div>
            </div>

            <a href="/properties" class="inline-flex items-center justify-center w-full mt-6 py-3 px-6 bg-transparent text-navy border border-mid/40 rounded font-medium hover:border-gold hover:text-gold transition-colors text-sm" data-i18n="back-listings">
              &larr; Volver a Propiedades
            </a>
          </aside>

        </div>
      </div>
    </section>
  </main>

  <!-- Footer injected -->
  
</Layout>
