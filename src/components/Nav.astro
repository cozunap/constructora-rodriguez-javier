---
// Nav.astro
const pathname = Astro.url.pathname;
const isHome = pathname === '/' || pathname === '/index.html';
const darkClass = isHome ? 'nav-dark' : '';
---
<nav class={`site-nav ${darkClass}`} id="site-nav">
  <div class="nav-inner">
    <a href="/" class="nav-logo" aria-label="Constructora Rodríguez Javier">
      <img src="/assets/lorenzo-logo.webp" alt="Logo">
    </a>
    <div class="nav-links" id="nav-links">
      <a href="/" class={isHome ? 'active' : ''} data-i18n="nav-home">Inicio</a>
      <a href="/properties" class={pathname.includes('/properties') ? 'active' : ''} data-i18n="nav-properties">Propiedades</a>
      <a href="/services" class={pathname.includes('/services') ? 'active' : ''} data-i18n="nav-services">Servicios</a>
      <a href="/about" class={pathname.includes('/about') ? 'active' : ''} data-i18n="nav-about">Nosotros</a>
      <a href="/contact" class={pathname.includes('/contact') ? 'active' : ''} data-i18n="nav-contact">Contacto</a>
      <a href="/contact" class="btn btn-primary nav-cta" data-i18n="nav-cta">Cotizar</a>
    </div>
    <button class="nav-hamburger" id="nav-hamburger" aria-label="Menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<script>
  // Navigation scripts (client side)
  document.addEventListener('DOMContentLoaded', () => {
    const nav = document.getElementById('site-nav');
    function onScroll() {
      if (nav) nav.classList.toggle('scrolled', window.scrollY > 40);
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    const ham = document.getElementById('nav-hamburger');
    const menu = document.getElementById('nav-links');
    if (ham && menu) {
      ham.addEventListener('click', () => {
        const open = menu.classList.toggle('open');
        ham.classList.toggle('open', open);
        ham.setAttribute('aria-expanded', String(open));
        document.body.classList.toggle('no-scroll', open);
      });
    }
  });
</script>
