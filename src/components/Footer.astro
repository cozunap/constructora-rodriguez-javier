      </div>
      <div class="footer-col">
        <h4 data-i18n="footer-pages">Páginas</h4>
        <ul>
          <li><a href="/" data-i18n="nav-home">Inicio</a></li>
          <li><a href="/properties" data-i18n="nav-properties">Propiedades</a></li>
          <li><a href="/services" data-i18n="nav-services">Servicios</a></li>
          <li><a href="/about" data-i18n="nav-about">Nosotros</a></li>
          <li><a href="/contact" data-i18n="nav-contact">Contacto</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4 data-i18n="footer-services-title">Servicios</h4>
        <ul>
          <li><a href="/services" data-i18n="srv-interior-title">Diseño de Interiores</a></li>
          <li><a href="/services" data-i18n="srv-civil-title">Construcción</a></li>
          <li><a href="/services" data-i18n="srv-wood-title">Ebanistería</a></li>
          <li><a href="/services" data-i18n="srv-project-title">Gestión de Obra</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4 data-i18n="footer-contact-title">Contacto</h4>
        <ul>
          <li><a href="tel:+18299595350">+1 (829) 959-5350</a></li>
          <li><a href="mailto:info@crjavier.com">info@crjavier.com</a></li>
          <li><a href="#" data-i18n="footer-location">Santo Domingo, RD</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; <span id="footer-year"></span> Constructora Rodríguez Javier SRL. <span data-i18n="footer-rights">Todos los derechos reservados.</span></p>
      <p>Diseñado por <a href="https://cozuna.com" target="_blank">cozuna.com</a></p>
