---
// Footer.astro
---
<footer class="bg-navy text-white py-16 md:py-24 border-t border-navy-mid/30">
  <div class="w-full max-w-7xl mx-auto px-4 sm:px-6 md:px-8 lg:px-12 xl:px-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8 mb-16">
      <div class="space-y-6">
        <a href="/" class="inline-block"><img src="/assets/lorenzo-logo.webp" alt="Logo" class="h-16 w-auto brightness-0 invert opacity-90 hover:opacity-100 transition-opacity"></a>
        <p class="text-white/70 text-sm leading-relaxed max-w-sm" data-i18n="footer-desc">Transformando espacios con calidad, puntualidad y excelencia en Santo Domingo.</p>
      </div>
      <div>
        <h4 class="text-gold font-serif text-xl mb-6 tracking-wide" data-i18n="footer-pages">Páginas</h4>
        <ul class="space-y-3">
          <li><a href="/" class="text-white/70 hover:text-white transition-colors text-sm" data-i18n="nav-home">Inicio</a></li>
          <li><a href="/properties" class="text-white/70 hover:text-white transition-colors text-sm" data-i18n="nav-properties">Propiedades</a></li>
          <li><a href="/services" class="text-white/70 hover:text-white transition-colors text-sm" data-i18n="nav-services">Servicios</a></li>
          <li><a href="/about" class="text-white/70 hover:text-white transition-colors text-sm" data-i18n="nav-about">Nosotros</a></li>
          <li><a href="/contact" class="text-white/70 hover:text-white transition-colors text-sm" data-i18n="nav-contact">Contacto</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-gold font-serif text-xl mb-6 tracking-wide" data-i18n="footer-services-title">Servicios</h4>
        <ul class="space-y-3">
          <li><a href="/services" class="text-white/70 hover:text-white transition-colors text-sm" data-i18n="srv-interior-title">Diseño de Interiores</a></li>
          <li><a href="/services" class="text-white/70 hover:text-white transition-colors text-sm" data-i18n="srv-civil-title">Construcción</a></li>
          <li><a href="/services" class="text-white/70 hover:text-white transition-colors text-sm" data-i18n="srv-wood-title">Ebanistería</a></li>
          <li><a href="/services" class="text-white/70 hover:text-white transition-colors text-sm" data-i18n="srv-project-title">Gestión de Obra</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-gold font-serif text-xl mb-6 tracking-wide" data-i18n="footer-contact-title">Contacto</h4>
        <ul class="space-y-3">
          <li><a href="tel:+18299595350" class="text-white/70 hover:text-white transition-colors text-sm">+1 (829) 959-5350</a></li>
          <li><a href="mailto:info@crjavier.com" class="text-white/70 hover:text-white transition-colors text-sm">info@crjavier.com</a></li>
          <li><span class="text-white/70 text-sm" data-i18n="footer-location">Santo Domingo, RD</span></li>
        </ul>
      </div>
    </div>
    <div class="pt-8 border-t border-white/10 flex flex-col md:flex-row items-center justify-between gap-4 text-xs text-white/50">
      <p>&copy; <span id="footer-year"></span> Constructora Rodríguez Javier SRL. <span data-i18n="footer-rights">Todos los derechos reservados.</span></p>
      <p>Diseñado por <a href="https://cozuna.com" target="_blank" class="hover:text-white transition-colors">cozuna.com</a></p>
    </div>
  </div>
</footer>

<div class="fixed bottom-6 right-6 z-40 flex flex-col items-end pointer-events-none">
  <div class="bg-white rounded-xl shadow-2xl shadow-dark/20 w-80 mb-4 overflow-hidden pointer-events-auto transition-all duration-300 origin-bottom-right scale-0 opacity-0" id="wa-box">
    <div class="bg-navy p-5 flex items-center gap-4">
      <div class="w-12 h-12 bg-white rounded-full flex items-center justify-center text-2xl shadow-inner">👷</div>
      <div>
        <h4 class="text-white font-medium" data-i18n="wa-header">Chat de Soporte</h4>
        <span class="text-white/70 text-xs" data-i18n="wa-subheader">Responde en minutos</span>
      </div>
    </div>
    <div class="p-6 bg-light flex flex-col gap-4">
      <div class="bg-white p-4 rounded-xl rounded-tl-none shadow-sm text-sm text-dark self-start" data-i18n="wa-welcome">¡Hola! 👋 ¿En qué podemos ayudarte?</div>
      <a href="https://wa.me/18299595350?text=Hola%2C%20me%20interesa%20conocer%20m%C3%A1s%20sobre%20sus%20propiedades." target="_blank" class="btn-gold self-center w-full justify-center">
        <span data-i18n="wa-btn">Iniciar Chat</span>
      </a>
    </div>
  </div>
  <div class="flex gap-4 pointer-events-auto items-end">
    <button class="w-12 h-12 bg-navy text-white rounded-full flex items-center justify-center shadow-lg hover:-translate-y-1 transition-all duration-300 opacity-0 pointer-events-none invisible" id="back-to-top" aria-label="Back to top">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="18 15 12 9 6 15"/></svg>
    </button>
    <button class="w-16 h-16 bg-[#25D366] text-white rounded-full flex items-center justify-center shadow-xl shadow-[#25D366]/30 hover:-translate-y-1 hover:shadow-2xl transition-all duration-300" id="wa-toggle" aria-label="WhatsApp">
      <svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor"><path d="M12.012 2c-5.506 0-9.988 4.482-9.988 9.988 0 1.76.459 3.473 1.332 4.978L2 22l5.234-1.373a9.927 9.927 0 0 0 4.778 1.217c5.506 0 9.988-4.482 9.988-9.988C22 6.482 17.518 2 12.012 2zm4.72 13.916c-.208.583-1.026 1.133-1.636 1.258-.52.106-1.196.187-3.488-.763-2.929-1.217-4.82-4.204-4.965-4.4a5.19 5.19 0 0 1-.989-2.775c0-1.467.77-2.196 1.04-2.467.27-.27.583-.343.78-.343.197 0 .395.002.562.01.176.009.416-.067.65.49.25.593.853 2.08.926 2.227.073.146.125.323.02.52-.104.208-.156.323-.312.5-.156.177-.323.395-.468.531-.166.156-.343.323-.146.666.197.333.884 1.457 1.894 2.352 1.3 1.155 2.394 1.51 2.738 1.676.343.167.541.135.739-.094.197-.229.853-1.009 1.082-1.353.229-.343.458-.291.77-.177.312.115 1.977.968 2.31 1.135.333.166.552.25.635.395.083.146.083.843-.125 1.427z"/></svg>
    </button>
  </div>
</div>

<style>
  #wa-box.open {
    @apply scale-100 opacity-100;
  }
  #back-to-top.visible {
    @apply opacity-100 pointer-events-auto visible;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const yearEl = document.getElementById('footer-year');
    if (yearEl) yearEl.textContent = String(new Date().getFullYear());

    const toggle = document.getElementById('wa-toggle');
    const box    = document.getElementById('wa-box');
    if (toggle && box) {
      toggle.addEventListener('click', () => box.classList.toggle('open'));
    }

    const btn = document.getElementById('back-to-top');
    if (btn) {
      window.addEventListener('scroll', () => {
        if (window.scrollY > 400) {
          btn.classList.add('visible');
        } else {
          btn.classList.remove('visible');
        }
      }, { passive: true });
      btn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
    }

    const els = document.querySelectorAll('.fade-up');
    if (els.length) {
      const obs = new IntersectionObserver(entries => {
        entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); } });
      }, { threshold: 0.12 });
      els.forEach(el => obs.observe(el));
    }
  });
</script>
