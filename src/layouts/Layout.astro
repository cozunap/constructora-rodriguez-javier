---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
	title: string;
    navTheme?: 'dark' | 'light';
}

const { title, navTheme = 'dark' } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <meta name="description" content="Constructora Rodríguez Javier - Desarrollos Inmobiliarios y Diseño de Interiores en Santo Domingo.">
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;600&family=Inter:wght@300;400;500;600&family=Playfair+Display:wght@400;600;700&display=swap" rel="stylesheet">
    <!-- Language detection runs FIRST (blocking) to avoid flash of wrong language -->
    <script src="/js/lang.js" is:inline></script>
</head>
<body>
    <Nav theme={navTheme} />
    
    <main>
        <slot />
    </main>

    <Footer />

    <!-- App logic runs after DOM is ready -->
    <script src="/js/app.js" is:inline></script>
</body>
</html>
