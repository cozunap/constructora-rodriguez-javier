---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
	title: string;
    navTheme?: 'dark' | 'light';
    description?: string;
    image?: string;
    url?: string;
}

const { 
    title, 
    navTheme = 'dark',
    description = "Constructora Rodríguez Javier - Desarrollos Inmobiliarios y Diseño de Interiores en Santo Domingo.",
    image = "https://e0a90387.constructora-rodriguez-javier.pages.dev/assets/images/hero/hero-bg.webp",
    url = Astro.url.href
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <meta name="description" content={description}>
    
    <!-- OpenGraph Tags -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:url" content={url} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Canonical & Sitemap -->
    <link rel="canonical" href={url} />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-C661M62200"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-C661M62200');
    </script>

    <!-- JSON-LD Schema -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "RealEstateAgent",
      "name": "Constructora Rodríguez Javier",
      "url": "https://www.tucasard.com/",
      "logo": "https://www.tucasard.com/assets/lorenzo-logo.webp",
      "image": "https://www.tucasard.com/assets/images/hero/hero-bg.webp",
      "description": "Constructora Rodríguez Javier - Desarrollos Inmobiliarios y Diseño de Interiores en Santo Domingo.",
      "telephone": "+16468831869",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Santo Domingo",
        "addressCountry": "DO"
      }
    })} />
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;600&family=Inter:wght@300;400;500;600&family=Playfair+Display:wght@400;600;700&display=swap" rel="stylesheet">
    <!-- Language detection runs FIRST (blocking) to avoid flash of wrong language -->
    <script src="/js/lang.js?v=5" is:inline></script>
</head>
<body>
    <Nav theme={navTheme} />
    
    <main>
        <slot />
    </main>

    <Footer />

    <!-- App logic runs after DOM is ready -->
    <script src="/js/app.js?v=6" is:inline></script>
</body>
</html>
